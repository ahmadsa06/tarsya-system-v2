# إعدادات Apache لاستضافة التصدير الثابت لـ "ترسية" على Hostinger (system.tarsya.net)

# صفحة 404 المخصّصة من Next
ErrorDocument 404 /404.html

# ضغط المخرجات
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain application/javascript application/json image/svg+xml
</IfModule>

# سياسة التخزين المؤقت
<IfModule mod_headers.c>
  # أصول Next المبصومة (هاش في الاسم) — تخزين طويل وآمن
  <FilesMatch "\.(js|css|woff2?|ttf|otf|svg|png|jpe?g|gif|ico|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # صفحات HTML — بلا تخزين طويل ليظهر أي تحديث فوراً
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
